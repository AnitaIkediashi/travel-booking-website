model User {
    id                  String               @id @default(cuid())
    name                String
    email               String               @unique
    image               String?
    coverImage          String?
    phoneNo             String?
    address             String?
    password            String
    stripeCustomerId    String?              @unique
    cards               CardDetails[]
    accounts            Account[]
    passwordResetTokens PasswordResetToken[]
}
