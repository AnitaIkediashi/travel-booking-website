model CardDetails {
    id                    String      @id @default(uuid())
    stripePaymentMethodId String      @unique // The "Token" from Stripe
    cardType              String? // e.g., "visa", "mastercard"
    last4                 String // e.g., "4242"
    expMonth              Int
    expYear               Int
    cardName              String
    country               String
    userId                String
    user           User @relation(fields: [userId], references: [id], onDelete: Cascade)
    @@index([userId])
}


