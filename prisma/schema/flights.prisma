// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//creating the tables/models i need for my app

model Airport {
  airport_code      String    @id // PK
  airport_name      String
  image_url         String? // optional field
  city              String
  country           String
  departure_segments Segment[] @relation("DepartureSegment") // using a unique name for relation because a single Airport is related to Segment twice same goes for Legs model -- 1:M relation with Segment
  arrival_segments   Segment[] @relation("ArrivalSegment") // 1:M relation with Segment
  departure_legs     Legs[]    @relation("DepartureLegs") // 1:M relation with Legs
  arrival_legs      Legs[]    @relation("ArrivalLegs") // 1:M relation with Legs

  @@map("airports")
}

model Data {
  id            String         @id @default(uuid()) // PK
  createdAt     DateTime       @default(now())
  flight_offers FlightOffers[] // 1:M relation

  @@map("data")
}

model MinPrice {
  id                   Int       @id @default(autoincrement()) // PK
  min_price_airline_id String?   @unique // FK
  currency_code        String?
  amount               Int
  minPricePerAirline   Airlines? @relation(fields: [min_price_airline_id], references: [id], onDelete: Cascade) // relation to Airlines model the onDelete: Cascade ensures that if a Data record is deleted, all related MinPrice records are also deleted

  @@map("min_price")
}

model Airlines {
  id         String     @id @default(uuid()) // PK
  airline_id String // FK
  name       String
  logo       String
  iata_code  String     @unique
  min_price  MinPrice?
  carriers   Carriers[]

  @@map("airlines")
}

enum TripType {
  ONE_WAY
  ROUND_TRIP
}

model FlightOffers {
  id               String           @id @default(uuid()) // PK
  flight_offer_id  String // FK
  price_id         Int? // FK
  total_duration   Int // sum of segments and layover times between
  trip_type        TripType         @default(ONE_WAY) // be it One way or Round trip
  token            String           @unique
  flight_key       String
  segments         Segment[]
  price_breakdown  PriceBreakdown? // 1-to-1: Total price for this specific offer
  traveler_price   TravelerPrice[] // 1-to-Many: Breakdown per passenger type (ADULT, CHILD, INFANT)
  branded_fareinfo BrandedFareInfo?
  seats            Seat[]
  FlightData       Data             @relation(fields: [flight_offer_id], references: [id], onDelete: Cascade)
  bookings         Booking[]

  @@map("flight_offers")
}

model Segment {
  id                     String            @id @default(uuid()) // PK
  segment_id             String // FK
  departure_airport_code String //FK
  arrival_airport_code   String //FK
  marketingCarrierId     Int
  operatingCarrierId     Int?
  cabin_class            String
  slice_index            Int               @default(0) // 0 = Outbound, 1 = Inbound
  seat_availability      SeatAvailability?
  departure_airports     Airport           @relation("DepartureSegment", fields: [departure_airport_code], references: [airport_code]) // the need for unique relation names arises because a single Airport is related to Segment twice (same goes for Legs model) -- Disambiguating relations
  arrival_airports       Airport           @relation("ArrivalSegment", fields: [arrival_airport_code], references: [airport_code])
  departure_time         DateTime
  arrival_time           DateTime
  duration               Int // The total duration for that specific flight number, including ground time/layovers if the flight makes intermediate technical or passenger stops on the same flight number.
  flight_info            FlightInfo?
  legs                   Legs[]
  marketingCarrier       Carriers          @relation("MarketingCarrier", fields: [marketingCarrierId], references: [id])
  operatingCarrier       Carriers?         @relation("OperatingCarrier", fields: [operatingCarrierId], references: [id])
  segmentData            FlightOffers      @relation(fields: [segment_id], references: [id], onDelete: Cascade)

  //index the departure_time for faster queries and faster cpu performance -- its like sorting in advance or like map the data based on departure_time

  @@index([departure_time])
  @@index([departure_airport_code, arrival_airport_code])
  @@map("segments")
}

model Legs {
  id                     Int      @id @default(autoincrement()) // PK
  leg_id                 String // FK
  departure_airport_code String //FK
  arrival_airport_code   String //FK
  departure_time         DateTime
  arrival_time           DateTime
  duration               Int //The actual air time of a single non-stop flight from takeoff to landing.
  departure_gate_id      Int?     
  arrival_gate_id        Int?     
  departure_airport      Airport  @relation("DepartureLegs", fields: [departure_airport_code], references: [airport_code])
  arrival_airport        Airport  @relation("ArrivalLegs", fields: [arrival_airport_code], references: [airport_code])
  departure_gate         Gate?    @relation("DepartureGateOf", fields: [departure_gate_id], references: [id])
  arrival_gate           Gate?    @relation("ArrivalGateOf", fields: [arrival_gate_id], references: [id])
  legSegment             Segment  @relation(fields: [leg_id], references: [id], onDelete: Cascade)

  @@map("legs")
}

model Carriers {
  id         Int    @id @default(autoincrement()) // PK
  carrier_id String // FK 
  name       String
  logo       String
  code       String

  // Relations
  airline Airlines @relation(fields: [code], references: [iata_code], onDelete: Cascade)

  // A carrier can be used across multiple segments as a marketing or operating carrier
  marketingSegments Segment[] @relation("MarketingCarrier")
  operatingSegments Segment[] @relation("OperatingCarrier")

  @@map("carrier")
}

model FlightInfo {
  id             Int     @id @default(autoincrement()) // PK
  flight_info_id String  @unique // FK
  flight_number  String
  flightSegment  Segment @relation(fields: [flight_info_id], references: [id], onDelete: Cascade)

  @@map("flight_info")
}

model PriceBreakdown {
  id              Int    @id @default(autoincrement())
  flight_offer_id String @unique // 1-to-1 strict link
  currency_code   String @default("USD")

  total_amount    Decimal  @db.Decimal(10, 2)
  base_amount     Decimal  @db.Decimal(10, 2)
  tax_amount      Decimal  @db.Decimal(10, 2)
  discount_amount Decimal? @default(0) @db.Decimal(10, 2)

  flightOffer FlightOffers @relation(fields: [flight_offer_id], references: [id], onDelete: Cascade)

  @@map("price_breakdowns")
}

model TravelerPrice {
  id              Int    @id @default(autoincrement())
  flight_offer_id String
  passenger_type  String // ADT, CHD, INF
  quantity        Int // e.g. 2 Adults

  base_fare     Decimal @db.Decimal(10, 2)
  tax_amount    Decimal @db.Decimal(10, 2)
  total_per_pax Decimal @db.Decimal(10, 2)

  flightOffer FlightOffers @relation(fields: [flight_offer_id], references: [id], onDelete: Cascade)

  @@map("passenger_fares")
}

model SeatAvailability {
  id                         Int      @id @default(autoincrement()) // PK
  seat_availability_id       String   @unique // FK
  seats_left                 Int
  seatAvailabilityPerSegment Segment? @relation(fields: [seat_availability_id], references: [id], onDelete: Cascade)

  @@map("seat_availability")
}

model BrandedFareInfo {
  id                       Int          @id @default(autoincrement()) // PK
  branded_fareinfo_id      String       @unique // FK
  cabin_class              String
  features                 Features[]
  brandedFareInfoPerFlight FlightOffers @relation(fields: [branded_fareinfo_id], references: [id], onDelete: Cascade)

  @@map("branded_fare_info")
}

model Features {
  id                     Int             @id @default(autoincrement()) // PK
  feature_id             Int // FK
  feature_name           String
  category               String
  availability           String
  featureBrandedFareInfo BrandedFareInfo @relation(fields: [feature_id], references: [id], onDelete: Cascade)

  @@map("features")
}

model Gate {
  id              Int    @id @default(autoincrement())
  gate_number     String
  terminal        String
  departureForLeg Legs[]  @relation("DepartureGateOf")
  arrivalForLeg   Legs[]  @relation("ArrivalGateOf")

  @@map("gates")
}

model Seat {
  id          Int          @id @default(autoincrement())
  seat_id     String // FK -> FlightOffers
  seat_number String // e.g. "14A"
  cabin_class String
  is_window   Boolean
  is_aisle    Boolean
  is_exit_row Boolean
  is_booked   Boolean      @default(false)
  extra_fee   Int          @default(0) // derived from window/exit-row tiers
  seatFlight  FlightOffers @relation(fields: [seat_id], references: [id], onDelete: Cascade)
  booking_id  String?
  booking     Booking?     @relation(fields: [booking_id], references: [id])
  held_until  DateTime?
  passenger   Passenger?

  @@unique([seat_id, seat_number])
  @@index([booking_id])
  @@map("seats")
}

model Booking {
  id              String        @id @default(uuid())
  flight_offer_id String
  flightOffer     FlightOffers  @relation(fields: [flight_offer_id], references: [id], onDelete: Cascade)
  status          BookingStatus @default(IN_PROGRESS)
  total_travelers Int
  hold_expires_at DateTime? // set once seats are picked; null before that
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt
  passengers      Passenger[]
  seats           Seat[]

  @@map("bookings")
}

enum BookingStatus {
  IN_PROGRESS
  HELD
  CONFIRMED
  EXPIRED
  CANCELLED
}

model Passenger {
  id              String   @id @default(uuid())
  booking_id      String
  booking         Booking  @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  first_name      String
  last_name       String
  gender          String
  id_type         String // "passport" | "national_id"
  id_number       String
  nationality     String
  date_of_birth   DateTime
  seat_id         Int?     @unique // FK -> Seat, nullable until seat step is done
  passenger_index Int
  seat            Seat?    @relation(fields: [seat_id], references: [id])

  @@map("passengers")
}
